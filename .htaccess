# ═══════════════════════════════════════════
#  NEOFINANCE — Security & Clean URLs
# ═══════════════════════════════════════════

Options -Indexes -MultiViews
ServerSignature Off

# ── Security Headers ──────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── Block sensitive & internal files ──────
<FilesMatch "^(db|_head|_add_jago|AGENTS|CLAUDE|README|style)\.(php|css|md|txt)?$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|sh|log|md|json|env|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block old root-level API files (moved to src/)
<FilesMatch "^(api_data|api_flow|transaction_actions|settings_actions|auth_actions)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Rewrite rules ─────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block .git
    RewriteRule ^\.git - [F,L]

    # Already a real file or directory
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Clean URL routing for pages
    RewriteRule ^([a-zA-Z][a-zA-Z0-9_-]*)/?$ $1.php [NC,L]
</IfModule>

# ── PHP Settings ───────────────────────────
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>